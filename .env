# 키 템플릿 (git에 커밋되는 유일한 env 파일).
# 실제 값은 로컬: .env.local / 배포: Render 대시보드 환경변수에서 주입한다.

# Database
DATABASE_URL=

# Server
PORT=4000

# 인증 (Google OAuth + JWT)
# 구글 클라우드 콘솔에서 OAuth 클라이언트 생성 후 입력. 승인된 리디렉션 URI에 GOOGLE_CALLBACK_URL 등록 필요.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
FRONTEND_URL=http://localhost:3000
JWT_SECRET=

# data.go.kr 단일 API 키 (국가유산청 Open API 포함)
DATA_GO_KR_API_KEY=

# Cloudflare R2 (S3 호환)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=
